---
import Base from '../../../layouts/Base.astro';
import { loadPosts } from '../../../lib/blog';

export function getStaticPaths() {
  return loadPosts()
    .filter((p) => p.lang === 'zh')
    .map((p) => ({
      params: { slug: p.slug },
      props: { post: p },
    }));
}

const { post } = Astro.props as { post: ReturnType<typeof loadPosts>[number] };
---
<Base title={post.title} current="blog" description={post.excerpt} lang="zh">
  <article class="post">
    <p class="post-back"><a href="/zh/blog">← 所有文章</a></p>
    <header class="post-head">
      <p class="post-meta">{post.date} · {post.reading} · 笔记</p>
      <h1 class="post-title">{post.title}</h1>
      <p class="post-deck">{post.excerpt}</p>
    </header>
    <div class="post-body" set:html={post.bodyHtml}></div>
    <footer class="post-foot">
      <p>
        <a href="/zh/blog">← 所有文章</a>
        <span style="color: var(--border-default); margin: 0 12px;">·</span>
        <a href="/zh/marketplace">浏览市场</a>
      </p>
    </footer>
  </article>
</Base>

<style>
  .post {
    max-width: 720px;
    margin: 0 auto;
    padding: 32px var(--s-4) 80px;
  }
  .post-back { font-size: 13px; margin: 0 0 32px; }
  .post-back a { color: var(--fg-muted); text-decoration: none; }
  .post-back a:hover { color: var(--accent-fg); }
  .post-head {
    margin-bottom: 48px;
    padding-bottom: 32px;
    border-bottom: 1px solid var(--border-muted);
  }
  .post-meta {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 16px;
  }
  .post-title {
    font-size: clamp(32px, 4.5vw, 52px);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin: 0 0 20px;
    border: 0;
    padding: 0;
    color: var(--fg-default);
  }
  .post-deck {
    font-size: 18px;
    line-height: 1.55;
    color: var(--fg-muted);
    margin: 0;
    max-width: 60ch;
    letter-spacing: -0.005em;
  }
  .post-body { font-size: 17px; line-height: 1.7; color: var(--fg-default); }
  .post-body :global(p) { margin: 0 0 24px; }
  .post-body :global(h1) {
    font-size: 32px; font-weight: 700;
    letter-spacing: -0.025em; line-height: 1.1;
    margin: 56px 0 20px; border: 0; padding: 0;
  }
  .post-body :global(h1):first-child { display: none; }
  .post-body :global(h2) {
    font-size: 26px; font-weight: 700;
    letter-spacing: -0.02em; line-height: 1.15;
    margin: 56px 0 16px; border: 0; padding: 0;
  }
  .post-body :global(h3) {
    font-size: 19px; font-weight: 600;
    letter-spacing: -0.012em; margin: 40px 0 12px;
  }
  .post-body :global(ul), .post-body :global(ol) { padding-left: 24px; margin: 0 0 24px; }
  .post-body :global(li) { margin-bottom: 8px; }
  .post-body :global(a) {
    color: var(--accent-fg); text-decoration: underline;
    text-decoration-color: var(--accent-muted); text-underline-offset: 3px;
  }
  .post-body :global(a:hover) { text-decoration-color: var(--accent-emphasis); }
  .post-body :global(code) {
    font-size: 14px; background: var(--bg-emph);
    border-radius: 4px; padding: 1px 6px;
  }
  .post-body :global(pre) {
    background: var(--bg-subtle);
    border: 1px solid var(--border-muted);
    border-radius: var(--r-2);
    padding: 16px 20px; overflow-x: auto;
    margin: 0 0 24px; font-size: 13px; line-height: 1.7;
  }
  .post-body :global(pre code) { background: transparent; padding: 0; font-size: 13px; }
  .post-body :global(blockquote) {
    border-left: 3px solid var(--accent-emphasis);
    margin: 24px 0; padding: 4px 24px;
    color: var(--fg-default); font-size: 18px; line-height: 1.55;
  }
  .post-body :global(table) { width: 100%; margin: 24px 0; font-size: 14px; }
  .post-body :global(table th), .post-body :global(table td) {
    padding: 10px 14px; border: 1px solid var(--border-default);
    text-align: left; vertical-align: top;
  }
  .post-body :global(table th) { background: var(--bg-subtle); font-weight: 600; }
  .post-body :global(hr) { border: 0; border-top: 1px solid var(--border-muted); margin: 48px 0; }
  .post-foot {
    margin-top: 64px; padding-top: 32px;
    border-top: 1px solid var(--border-muted);
    font-size: 14px; color: var(--fg-muted);
  }
  .post-foot a { color: var(--fg-default); text-decoration: none; }
  .post-foot a:hover { color: var(--accent-fg); }
</style>
