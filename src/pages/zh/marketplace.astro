---
import Base from '../../layouts/Base.astro';
import { loadAll, allKinds } from '../../lib/corpus';

const { corpora: packs } = loadAll();
const kinds = allKinds();

const fmt = new Intl.NumberFormat('zh-CN');

const featured = packs.find((c) => c.slug === 'frontend-design');
const others = packs.filter((c) => c.slug !== 'frontend-design')
  .sort((a, b) => b.total - a.total);

function summarise(c: typeof packs[0]) {
  const ns = [...new Set(c.atoms.map((a) => a.prefix))];
  const ks = [...new Set(c.atoms.map((a) => a.kind))];
  return { ns, ks };
}
---
<Base
  title="市场"
  current="marketplace"
  lang="zh"
  description="浏览 Skill Wiki 上的 Prime —— 横跨设计、后端、安全等领域，可插入任意 MCP 兼容 AI 代理。每个 Prime 是一个自洽的 @scope，包含规则、术语、方法与模式。"
>
  <section class="hero" style="padding: var(--s-7) var(--s-4) var(--s-6);">
    <div class="hero-inner" style="grid-template-columns: 1fr; gap: 0;">
      <div>
        <p class="hero-eyebrow">
          <span class="pill">市场</span>
          {packs.length} 个 Prime · 共 {fmt.format(packs.reduce((s, c) => s + c.total, 0))} 个原子
        </p>
        <h1>浏览 Prime。</h1>
        <p class="lede">
          每个 Prime 是一个自洽的 <code>@scope</code> —— 一组类型化原子。
          用 <code>prime install @name</code> 装上，或在这里浏览。协议 domain-blind，
          知识活在 Prime 里 —— 设计、后端、安全都在同一套协议上。
        </p>
        <p class="lede" style="margin-bottom: 0;">
          想发布自己的？看 <a href="/zh/docs/usage/publish-install">发布与安装</a>。
        </p>
      </div>
    </div>
  </section>

  {featured && (() => {
    const { ns, ks } = summarise(featured);
    return (
      <section class="section" id="frontend-design">
        <div class="section-inner">
          <p class="section-eyebrow">★ 旗舰</p>
          <div class="flagship">
            <div class="flagship-head">
              <span class="label">旗舰</span>
              <span style="font-family: var(--font-mono); color: var(--fg-muted);">
                <a href="https://github.com/skill-wiki/prime-corpus-frontend" rel="noopener">skill-wiki/prime-corpus-frontend</a>
              </span>
            </div>
            <div class="flagship-body">
              <div>
                <h2><code>@frontend-design</code></h2>
                <p class="flagship-desc">
                  {fmt.format(featured.total)} 个类型化原子，覆盖 9 个设计子领域 ——
                  色彩、版式、动效、间距、可访问性、文案语气、视觉层次、布局、组件模式。
                  参考语料 + 参考应用：5 工具 MCP 封装、31 个 persona、30 个任务分类、
                  20 任务 benchmark。
                </p>
                <dl>
                  <dt>原子</dt><dd>{fmt.format(featured.total)}</dd>
                  <dt>命名空间</dt><dd>{ns.length}（{ns.slice(0, 3).join('、')}…）</dd>
                  <dt>使用 kind</dt><dd>{ks.length} / {kinds.length}</dd>
                  <dt>Token</dt><dd>编译产出 {fmt.format(featured.totalTokens || 0)}</dd>
                  <dt>许可</dt><dd>Apache-2.0</dd>
                </dl>
                <div class="flagship-install">bunx @prime-lang/mcp-server-frontend</div>
                <div class="hero-cta" style="margin-top: var(--s-4);">
                  <a class="btn btn-primary" href={`/browse?corpus=${featured.slug}`}>浏览 {featured.total} 个原子 →</a>
                  <a class="btn" href="/zh/docs/usage/install">安装</a>
                </div>
              </div>
              <aside class="flagship-aside">
                <div>
                  <h4>命名空间</h4>
                  <div class="chips">
                    {ns.map((p) => <code>{p}</code>)}
                  </div>
                </div>
                <div>
                  <h4>子领域</h4>
                  <div class="chips">
                    <code>color</code>
                    <code>typography</code>
                    <code>motion</code>
                    <code>spacing</code>
                    <code>a11y</code>
                    <code>voice</code>
                    <code>hierarchy</code>
                    <code>layout</code>
                    <code>components</code>
                  </div>
                </div>
                <div>
                  <h4>MCP 工具</h4>
                  <div class="chips">
                    <code>prime_query</code>
                    <code>prime_resolve</code>
                    <code>prime_intent</code>
                    <code>prime_validate</code>
                    <code>prime_compile</code>
                  </div>
                </div>
              </aside>
            </div>
          </div>
        </div>
      </section>
    );
  })()}

  <section class="section">
    <div class="section-inner">
      <p class="section-eyebrow">更多 Prime</p>
      <h2 class="section-title" style="border: 0; padding: 0; margin-top: 0;">领域 Prime 与示例包</h2>
      <p class="section-lede">
        覆盖后端架构、应用安全等领域的早期 Prime，加上几个用来学 DSL 或冒烟测试运行时的小示例。
      </p>
      <div class="pack-grid">
        {others.map((c) => {
          const { ks } = summarise(c);
          return (
            <a class="pack-card" id={c.slug} href={`/browse?corpus=${c.slug}`}>
              <div class="pack-head">
                <h3 class="pack-name">@{c.slug}</h3>
                <span class="pack-pill">{c.prefix}</span>
                <span class="pack-pill">v0.1.0</span>
              </div>
              <p class="pack-desc">
                {c.domain?.description ||
                  `${c.total} 个原子，覆盖 ${ks.length} 种 kind。示例 Prime。`}
              </p>
              <div class="pack-stats">
                <span><span class="dot" style="background: #1a7f37;"></span>{c.total} 原子</span>
                <span>{ks.length} kind</span>
                <span>v0.1.0</span>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-inner">
      <p class="section-eyebrow">发布自己的</p>
      <h2 class="section-title" style="border: 0; padding: 0; margin-top: 0;">把你的 Prime 加到这个市场</h2>
      <p class="section-lede">
        市场是 PR 驱动的。把你的 Prime push 到 GitHub，再开一个 PR
        把它加到本站仓的 <code>data/skills.yaml</code>。我们 review、merge，
        CI 自动重新渲染市场。
      </p>

      <div class="submit-grid">
        <div class="submit-step">
          <span class="submit-num">1</span>
          <h3>把 Prime push 到 GitHub</h3>
          <p>任何公开仓。用 <code>prime compile</code> 编译。Apache-2.0 或兼容许可。</p>
        </div>
        <div class="submit-step">
          <span class="submit-num">2</span>
          <h3>PR 一条 yaml 条目</h3>
          <p>在 <code>data/skills.yaml</code> 加 5 行。slug、repo、描述、tag。</p>
        </div>
        <div class="submit-step">
          <span class="submit-num">3</span>
          <h3>我们 merge，CI 重 build</h3>
          <p>下次部署后你的 Prime 出现在市场，约 5 分钟。</p>
        </div>
      </div>

      <div class="hero-cta" style="margin-top: 32px;">
        <a class="btn btn-primary" href="https://github.com/skill-wiki/skill-wiki.github.io/blob/main/CONTRIBUTING.md" rel="noopener">阅读发布指南 →</a>
        <a class="btn" href="https://github.com/skill-wiki/skill-wiki.github.io/edit/main/data/skills.yaml" rel="noopener">直接 PR</a>
      </div>

      <p style="margin-top: 24px; font-size: 13px; color: var(--fg-muted);">
        想要私有 / 企业 registry？<a href="/zh/docs/usage/publish-install">自托管参考 registry</a> —— 同样的协议，你的基础设施。
      </p>
    </div>
  </section>
</Base>

<style>
  .submit-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  @media (max-width: 800px) {
    .submit-grid { grid-template-columns: 1fr; gap: 12px; }
  }
  .submit-step {
    border: 1px solid var(--border-default);
    border-radius: var(--r-2);
    padding: 24px;
    background: var(--bg-canvas);
  }
  .submit-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px; height: 28px;
    border-radius: 999px;
    background: var(--accent-subtle);
    color: var(--accent-fg);
    border: 1px solid var(--accent-muted);
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 700;
    margin-bottom: 12px;
  }
  .submit-step h3 {
    font-size: 16px;
    font-weight: 600;
    letter-spacing: -0.012em;
    margin: 0 0 6px;
    border: 0; padding: 0;
  }
  .submit-step p {
    font-size: 13px;
    line-height: 1.55;
    color: var(--fg-muted);
    margin: 0;
  }
</style>
