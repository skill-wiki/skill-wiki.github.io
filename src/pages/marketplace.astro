---
import Base from '../layouts/Base.astro';
import { loadAll, allKinds } from '../lib/corpus';

const { corpora: packs } = loadAll();
const kinds = allKinds();

const fmt = new Intl.NumberFormat('en-US');

// Order: featured first (frontend-design), then by atom count desc.
const featured = packs.find((c) => c.slug === 'frontend-design');
const others = packs.filter((c) => c.slug !== 'frontend-design')
  .sort((a, b) => b.total - a.total);

function summarise(c: typeof packs[0]) {
  const ns = [...new Set(c.atoms.map((a) => a.prefix))];
  const ks = [...new Set(c.atoms.map((a) => a.kind))];
  return { ns, ks };
}
---
<Base
  title="Marketplace"
  current="marketplace"
  description="The Skill Wiki marketplace — typed-atom Primes covering design, backend, security and more. Plug into any MCP-compatible AI agent. Each Prime is a self-contained @scope of rules, terms, methods and patterns."
>
  <section class="hero" style="padding: var(--s-7) var(--s-4) var(--s-6);">
    <div class="hero-inner" style="grid-template-columns: 1fr; gap: 0;">
      <div>
        <p class="hero-eyebrow">
          <span class="pill">Skill Wiki · Marketplace</span>
          {packs.length} Primes · {fmt.format(packs.reduce((s, c) => s + c.total, 0))} atoms
        </p>
        <h1>The Skill Wiki marketplace.</h1>
        <p class="lede">
          Every entry here is a Prime — a self-contained <code>@scope</code> of
          typed atoms. What a <code>SKILL.md</code> would look like if every
          line had a type and an edge. Install with
          <code>prime install @name</code>, or browse below. Skill Wiki is
          domain-blind — design, backend and security all ride on the same
          open protocol.
        </p>
        <p class="lede" style="margin-bottom: 0;">
          Want to publish your own? See <a href="/docs/usage/publish-install">Publish & install</a>.
        </p>
      </div>
    </div>
  </section>

  {featured && (() => {
    const { ns, ks } = summarise(featured);
    return (
      <section class="section" id="frontend-design">
        <div class="section-inner">
          <p class="section-eyebrow">★ Featured</p>
          <div class="flagship">
            <div class="flagship-head">
              <span class="label">FLAGSHIP</span>
              <span style="font-family: var(--font-mono); color: var(--fg-muted);">
                <a href="https://github.com/skill-wiki/prime-corpus-frontend" rel="noopener">skill-wiki/prime-corpus-frontend</a>
              </span>
            </div>
            <div class="flagship-body">
              <div>
                <h2><code>@frontend-design</code></h2>
                <p class="flagship-desc">
                  {fmt.format(featured.total)} typed atoms across 9 design sub-domains —
                  color, typography, motion, spacing, accessibility, copy voice,
                  hierarchy, layout, and component patterns. Reference corpus +
                  reference application: 5-tool MCP wrapper, 31 personas, 30 task
                  taxonomies, 20-task benchmark.
                </p>
                <dl>
                  <dt>Atoms</dt><dd>{fmt.format(featured.total)}</dd>
                  <dt>Namespaces</dt><dd>{ns.length} ({ns.slice(0, 3).join(', ')}…)</dd>
                  <dt>Kinds used</dt><dd>{ks.length} of {kinds.length}</dd>
                  <dt>Tokens</dt><dd>{fmt.format(featured.totalTokens || 0)} compiled</dd>
                  <dt>License</dt><dd>Apache-2.0</dd>
                </dl>
                <div class="flagship-install">bunx @skill-wiki/mcp-server-frontend</div>
                <div class="hero-cta" style="margin-top: var(--s-4);">
                  <a class="btn btn-primary" href={`/browse?corpus=${featured.slug}`}>Browse {featured.total} atoms →</a>
                  <a class="btn" href="/docs/usage/install">Install</a>
                </div>
              </div>
              <aside class="flagship-aside">
                <div>
                  <h4>Namespaces</h4>
                  <div class="chips">
                    {ns.map((p) => <code>{p}</code>)}
                  </div>
                </div>
                <div>
                  <h4>Sub-domains</h4>
                  <div class="chips">
                    <code>color</code>
                    <code>typography</code>
                    <code>motion</code>
                    <code>spacing</code>
                    <code>a11y</code>
                    <code>voice</code>
                    <code>hierarchy</code>
                    <code>layout</code>
                    <code>components</code>
                  </div>
                </div>
                <div>
                  <h4>MCP tools</h4>
                  <div class="chips">
                    <code>prime_query</code>
                    <code>prime_resolve</code>
                    <code>prime_intent</code>
                    <code>prime_validate</code>
                    <code>prime_compile</code>
                  </div>
                </div>
              </aside>
            </div>
          </div>
        </div>
      </section>
    );
  })()}

  <section class="section">
    <div class="section-inner">
      <p class="section-eyebrow">More Primes</p>
      <h2 class="section-title" style="border: 0; padding: 0; margin-top: 0;">Domain Primes & starter examples</h2>
      <p class="section-lede">
        Early Primes covering backend architecture and application security,
        plus a couple of tiny example packs handy for learning the DSL or
        smoke-testing the runtime.
      </p>
      <div class="pack-grid">
        {others.map((c) => {
          const { ks } = summarise(c);
          return (
            <a class="pack-card" id={c.slug} href={`/browse?corpus=${c.slug}`}>
              <div class="pack-head">
                <h3 class="pack-name">@{c.slug}</h3>
                <span class="pack-pill">{c.prefix}</span>
                <span class="pack-pill">v0.1.0</span>
              </div>
              <p class="pack-desc">
                {c.domain?.description ||
                  `${c.total} typed atoms across ${ks.length} kinds. Example Prime.`}
              </p>
              <div class="pack-stats">
                <span><span class="dot" style="background: #1a7f37;"></span>{c.total} atoms</span>
                <span>{ks.length} kinds</span>
                <span>v0.1.0</span>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="section-inner">
      <p class="section-eyebrow">Publish your own</p>
      <h2 class="section-title" style="border: 0; padding: 0; margin-top: 0;">Add your Prime to this marketplace</h2>
      <p class="section-lede">
        The marketplace is PR-driven. Push your Prime to GitHub, then open one
        PR adding it to <code>data/skills.yaml</code> on this site's repo. We
        review, merge, and CI re-renders the marketplace.
      </p>

      <div class="submit-grid">
        <div class="submit-step">
          <span class="submit-num">1</span>
          <h3>Push your Prime to GitHub</h3>
          <p>Any public repo. Compile with <code>prime compile</code>. Apache-2.0 or compatible license.</p>
        </div>
        <div class="submit-step">
          <span class="submit-num">2</span>
          <h3>PR one yaml entry</h3>
          <p>Add a 5-line block to <code>data/skills.yaml</code>. Slug, repo, description, tags.</p>
        </div>
        <div class="submit-step">
          <span class="submit-num">3</span>
          <h3>We merge, CI rebuilds</h3>
          <p>Your Prime appears in the marketplace on next deploy. ~5 minutes.</p>
        </div>
      </div>

      <div class="hero-cta" style="margin-top: 32px;">
        <a class="btn btn-primary" href="https://github.com/skill-wiki/skill-wiki.github.io/blob/main/CONTRIBUTING.md" rel="noopener">Read the publishing guide →</a>
        <a class="btn" href="https://github.com/skill-wiki/skill-wiki.github.io/edit/main/data/skills.yaml" rel="noopener">Open a PR</a>
      </div>

      <p style="margin-top: 24px; font-size: 13px; color: var(--fg-muted);">
        Need a private / enterprise registry? <a href="/docs/usage/publish-install">Self-host the reference registry</a> — same protocol, your infra.
      </p>
    </div>
  </section>
</Base>

<style>
  .submit-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }
  @media (max-width: 800px) {
    .submit-grid { grid-template-columns: 1fr; gap: 12px; }
  }
  .submit-step {
    border: 1px solid var(--border-default);
    border-radius: var(--r-2);
    padding: 24px;
    background: var(--bg-canvas);
  }
  .submit-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px; height: 28px;
    border-radius: 999px;
    background: var(--accent-subtle);
    color: var(--accent-fg);
    border: 1px solid var(--accent-muted);
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 700;
    margin-bottom: 12px;
  }
  .submit-step h3 {
    font-size: 16px;
    font-weight: 600;
    letter-spacing: -0.012em;
    margin: 0 0 6px;
    border: 0; padding: 0;
  }
  .submit-step p {
    font-size: 13px;
    line-height: 1.55;
    color: var(--fg-muted);
    margin: 0;
  }
</style>
