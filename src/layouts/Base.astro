---
import '../styles/global.css';
import '../styles/mermaid.css';
import { totals } from '../lib/corpus';
const _t = totals();
const _atomsFmt = new Intl.NumberFormat('en-US').format(_t.atoms);

interface Props {
  title: string;
  description?: string;
  current?: 'home' | 'marketplace' | 'docs' | 'browse' | 'blog' | 'about';
  lang?: 'en' | 'zh';
  image?: string;
  type?: 'website' | 'article';
  published?: string;
}

const {
  title,
  description,
  current,
  lang = 'en',
  image = '/og-default.png',
  type = 'website',
  published,
} = Astro.props;
const isZh = lang === 'zh';

const fullTitle = title === 'Skill Wiki' ? title : `${title} · Skill Wiki`;
const desc =
  description ??
  (isZh
    ? 'Skill Wiki —— 把领域知识表达为类型化原子，按 ID 寻址、声明式边图、按需载入。由开放协议 Prime 提供支持。'
    : 'Skill Wiki — domain knowledge as typed atoms with a declared edge graph, retrieved on demand. Powered by the open Prime protocol.');

// Canonical URL — prefer Astro's configured site, fall back to org root.
const SITE = (import.meta.env.SITE as string | undefined) ?? 'https://skill-wiki.github.io';
const pathname = Astro.url.pathname;
const canonicalUrl = new URL(pathname, SITE).toString();
const ogImage = new URL(image, SITE).toString();
const ogLocale = isZh ? 'zh_CN' : 'en_US';

// hreflang alternates — strip /zh prefix for EN, add /zh for ZH.
// Edge case: root "/" <-> "/zh" (no trailing slash). Path "/zh" is treated
// the same as "/zh/". Anything that doesn't start with /zh is treated as EN.
function stripZh(p: string): string {
  if (p === '/zh' || p === '/zh/') return '/';
  if (p.startsWith('/zh/')) return p.slice(3); // "/zh/foo" -> "/foo"
  return p;
}
function addZh(p: string): string {
  if (p === '/' || p === '') return '/zh';
  return `/zh${p}`;
}
const enPath = pathname.startsWith('/zh') ? stripZh(pathname) : pathname;
const zhPath = pathname.startsWith('/zh') ? pathname : addZh(pathname);
const enUrl = new URL(enPath, SITE).toString();
const zhUrl = new URL(zhPath, SITE).toString();

// JSON-LD structured data — Organization on every page; Article on article pages.
const orgLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Skill Wiki',
  url: SITE,
  logo: new URL('/logo.png', SITE).toString(),
  sameAs: [
    'https://github.com/skill-wiki',
    'https://github.com/skill-wiki/prime-system',
  ],
};
const articleLd =
  type === 'article'
    ? {
        '@context': 'https://schema.org',
        '@type': 'Article',
        headline: title,
        description: desc,
        image: ogImage,
        datePublished: published,
        author: { '@type': 'Organization', name: 'Skill Wiki' },
        publisher: {
          '@type': 'Organization',
          name: 'Skill Wiki',
          logo: { '@type': 'ImageObject', url: new URL('/logo.png', SITE).toString() },
        },
        mainEntityOfPage: canonicalUrl,
      }
    : null;

const T = isZh
  ? {
      market: '市场',
      docs: '文档',
      blog: '日志',
      about: '关于',
      switch: 'EN',
      switchHref: '/',
    }
  : {
      market: 'Marketplace',
      docs: 'Docs',
      blog: 'Blog',
      about: 'About',
      switch: '中',
      switchHref: '/zh',
    };

const homeHref = isZh ? '/zh' : '/';
const prefix = (p: string) => (isZh ? `/zh${p}` : p);
---
<!doctype html>
<html lang={isZh ? 'zh-CN' : 'en'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={desc} />
    <link rel="icon" type="image/png" href="/favicon.png" />

    {/* Canonical + hreflang — tells Google which URL is the source of truth
        and which alternates exist for the same page in another language. */}
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="zh" href={zhUrl} />
    <link rel="alternate" hreflang="x-default" href={enUrl} />

    {/* Open Graph — shared link preview across Facebook, LinkedIn, Slack, etc. */}
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:site_name" content="Skill Wiki" />
    {type === 'article' && published && (
      <meta property="article:published_time" content={published} />
    )}

    {/* Twitter card — large summary preview. */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={desc} />
    <meta name="twitter:image" content={ogImage} />

    {/* JSON-LD structured data — Organization always, Article on blog posts. */}
    <script type="application/ld+json" set:html={JSON.stringify(orgLd)} />
    {articleLd && (
      <script type="application/ld+json" set:html={JSON.stringify(articleLd)} />
    )}

    {/* Pre-paint theme application — avoids flash on first load + on every nav. */}
    <script is:inline>
      (function () {
        try {
          var saved = localStorage.getItem('sw-theme');
          var prefersDark = window.matchMedia &&
            window.matchMedia('(prefers-color-scheme: dark)').matches;
          var theme = saved === 'dark' ? 'dark'
                    : saved === 'light' ? 'light'
                    : (prefersDark ? 'dark' : 'light');
          document.documentElement.dataset.theme = theme;
        } catch (e) { /* private mode etc. — fall back to OS default */ }
      })();
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
    />
  </head>
  <body>
    <a class="skip" href="#main">Skip to content</a>
    <header class="gh-header">
      <div class="gh-header-inner">
        <a class="gh-brand" href={homeHref} aria-label="Skill Wiki">
          <img src="/logo-mark.png" alt="" width="24" height="24" aria-hidden="true" />
          Skill Wiki
          <span class="gh-brand-tag">v0.1.0</span>
        </a>
        <div class="gh-search" role="search">
          <input
            type="search"
            placeholder={isZh ? '搜索原子、规范、文档…' : 'Search atoms, spec, docs…'}
            aria-label={isZh ? '搜索' : 'Search'}
          />
          <kbd>⌘ K</kbd>
        </div>
        <nav class="gh-nav" aria-label="Primary">
          <a href={prefix('/marketplace')} aria-current={current === 'marketplace' || current === 'browse' ? 'page' : undefined}>{T.market}</a>
          <a href={prefix('/docs')} aria-current={current === 'docs' ? 'page' : undefined}>{T.docs}</a>
          <a href={prefix('/blog')} aria-current={current === 'blog' ? 'page' : undefined}>{T.blog}</a>
          <a href={prefix('/about')} aria-current={current === 'about' ? 'page' : undefined}>{T.about}</a>
        </nav>
        <div class="gh-meta">
          <button id="theme-toggle" class="theme-toggle" aria-label="Toggle theme" type="button">
            <svg class="i-sun"  width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 11.5a3.5 3.5 0 1 1 0-7 3.5 3.5 0 0 1 0 7Zm0-1.5a2 2 0 1 0 0-4 2 2 0 0 0 0 4Zm0-9a.75.75 0 0 1 .75.75v1.5a.75.75 0 0 1-1.5 0V1.75A.75.75 0 0 1 8 1Zm0 11a.75.75 0 0 1 .75.75v1.5a.75.75 0 0 1-1.5 0v-1.5A.75.75 0 0 1 8 12ZM2.343 2.343a.75.75 0 0 1 1.06 0l1.061 1.06a.75.75 0 0 1-1.06 1.061L2.343 3.404a.75.75 0 0 1 0-1.06Zm9.193 9.193a.75.75 0 0 1 1.061 0l1.06 1.061a.75.75 0 1 1-1.06 1.06l-1.06-1.06a.75.75 0 0 1 0-1.061ZM1 8a.75.75 0 0 1 .75-.75h1.5a.75.75 0 0 1 0 1.5h-1.5A.75.75 0 0 1 1 8Zm11 0a.75.75 0 0 1 .75-.75h1.5a.75.75 0 0 1 0 1.5h-1.5A.75.75 0 0 1 12 8ZM2.343 13.657a.75.75 0 0 1 0-1.06l1.06-1.061a.75.75 0 1 1 1.061 1.06l-1.06 1.061a.75.75 0 0 1-1.061 0Zm9.193-9.193a.75.75 0 0 1 0-1.06l1.06-1.06a.75.75 0 1 1 1.061 1.06L12.597 4.464a.75.75 0 0 1-1.061 0Z"/></svg>
            <svg class="i-moon" width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M9.598 1.591a.75.75 0 0 1 .785-.175 7 7 0 1 1-8.967 8.967.75.75 0 0 1 .961-.96 5.5 5.5 0 0 0 7.046-7.046.75.75 0 0 1 .175-.786Zm1.616 1.945a7 7 0 0 1-7.678 7.678 5.499 5.499 0 1 0 7.678-7.678Z"/></svg>
          </button>
          <a href={T.switchHref} aria-label="Switch language">{T.switch}</a>
          <a href="https://github.com/skill-wiki/prime-system" rel="noopener" aria-label="GitHub">GitHub ↗</a>
        </div>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="gh-footer">
      <div class="gh-footer-inner">
        <div class="gh-footer-meta">
          <strong>Skill Wiki</strong> v0.1.0<br />
          {isZh
            ? '类型化原子、声明式边图、按需载入。由开放协议 Prime 驱动。'
            : 'Typed atoms, a declared edge graph, retrieved on demand. Powered by the open Prime protocol.'}
          <br /><br />
          Apache-2.0 licensed.
        </div>
        <div>
          <h4>{isZh ? '产品' : 'Product'}</h4>
          <ul>
            <li><a href={prefix('/marketplace')}>{T.market}</a></li>
            <li><a href={prefix('/docs/usage/install')}>{isZh ? '安装' : 'Install'}</a></li>
            <li><a href={prefix('/docs/spec/overview')}>{isZh ? '协议规范' : 'Specification'}</a></li>
          </ul>
        </div>
        <div>
          <h4>{isZh ? '开发者' : 'Developers'}</h4>
          <ul>
            <li><a href={prefix('/docs/architecture/pipeline')}>{isZh ? '架构' : 'Architecture'}</a></li>
            <li><a href={prefix('/docs/extending/custom-kinds')}>{isZh ? '拓展' : 'Extending'}</a></li>
            <li><a href={prefix('/docs/reference/cli')}>CLI</a></li>
            <li><a href={prefix('/docs/reference/mcp')}>MCP API</a></li>
          </ul>
        </div>
        <div>
          <h4>{isZh ? '资源' : 'Resources'}</h4>
          <ul>
            <li><a href={prefix('/blog')}>{T.blog}</a></li>
            <li><a href={prefix('/about')}>{T.about}</a></li>
            <li><a href="https://github.com/skill-wiki/prime-system" rel="noopener">GitHub</a></li>
            <li><a href="https://github.com/skill-wiki/prime-system/blob/main/LICENSE" rel="noopener">License</a></li>
          </ul>
        </div>
      </div>
      <div class="gh-footer-bottom">
        <span>© 2026 Skill Wiki contributors. Apache-2.0.</span>
        <span>{isZh ? `语料 v0.1.0 · ${_atomsFmt} atoms 编译` : `v0.1.0 · ${_atomsFmt} atoms compiled`}</span>
      </div>
    </footer>

    <script>
      // Theme toggle button — light → dark → light (auto becomes implicit when
      // user has never set, since we read OS pref).
      (function () {
        const btn = document.getElementById('theme-toggle');
        if (!btn) return;
        btn.addEventListener('click', () => {
          const cur = document.documentElement.dataset.theme;
          const next = cur === 'dark' ? 'light' : 'dark';
          document.documentElement.dataset.theme = next;
          try { localStorage.setItem('sw-theme', next); } catch {}
        });
      })();
    </script>

    <script>
      // Copy-button injection — adds a hover-visible "Copy" button to every
      // <pre> code block on the page. Idempotent (runs once per page).
      // Skips Mermaid wrappers (which render to <div>, not <pre>, but we
      // belt-and-suspenders the selector anyway).
      (function () {
        const w = window as unknown as { __copyBtnInit?: boolean };
        if (w.__copyBtnInit) return;
        w.__copyBtnInit = true;

        const isZh = document.documentElement.lang.startsWith('zh');
        const labels = isZh
          ? { copy: '复制', copied: '已复制' }
          : { copy: 'Copy', copied: 'Copied' };

        function attach() {
          const blocks = document.querySelectorAll<HTMLPreElement>(
            'pre:not(.mermaid):not([data-mermaid-src])'
          );
          blocks.forEach((pre) => {
            // Don't double-attach if the script re-runs after a partial nav.
            if (pre.querySelector(':scope > .copy-btn')) return;
            // Skip pre elements inside a mermaid wrapper (defensive — none
            // exist today, but cheap to check).
            if (pre.closest('.mermaid-wrapper')) return;

            const btn = document.createElement('button');
            btn.type = 'button';
            btn.className = 'copy-btn';
            btn.setAttribute('aria-label', labels.copy);
            btn.textContent = labels.copy;

            btn.addEventListener('click', async (e) => {
              e.preventDefault();
              e.stopPropagation();
              const text = pre.textContent ?? '';
              try {
                await navigator.clipboard.writeText(text);
              } catch {
                // Older browsers / file:// — fall back to a hidden textarea.
                const ta = document.createElement('textarea');
                ta.value = text;
                ta.setAttribute('readonly', '');
                ta.style.position = 'absolute';
                ta.style.left = '-9999px';
                document.body.appendChild(ta);
                ta.select();
                try { document.execCommand('copy'); } catch {}
                document.body.removeChild(ta);
              }
              btn.textContent = labels.copied;
              btn.classList.add('copied');
              window.setTimeout(() => {
                btn.textContent = labels.copy;
                btn.classList.remove('copied');
              }, 1200);
            });

            pre.appendChild(btn);
          });
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', attach, { once: true });
        } else {
          attach();
        }
      })();
    </script>
  </body>
</html>
