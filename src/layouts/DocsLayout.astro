---
import Base from './Base.astro';
import DocsSidebar from '../components/DocsSidebar.astro';
import { DOCS_FLAT, findNeighbors } from '../data/docs-tree';

interface Props {
  title: string;
  slug: string;            // empty for index, e.g. "spec/atoms"
  description?: string;
  lang?: 'en' | 'zh';
}
const { title, slug, description, lang = 'en' } = Astro.props;
const isZh = lang === 'zh';
const base = isZh ? '/zh/docs' : '/docs';
const { prev, next } = findNeighbors(slug);

// Breadcrumb: /docs > section > page
const segments = slug.split('/').filter(Boolean);
---
<Base title={title} description={description} current="docs" lang={lang}>
  <div class="docs-layout">
    <DocsSidebar current={slug} lang={lang} />

    <article class="docs-content">
      <p class="docs-breadcrumb">
        <a href={base}>{isZh ? '文档' : 'Docs'}</a>
        {segments.length > 0 && ' / '}
        {segments.map((s, i) => (
          <span>
            {i === segments.length - 1
              ? <span style="color: var(--fg-default)">{s}</span>
              : <a href={`${base}/${segments.slice(0, i + 1).join('/')}`}>{s}</a>}
            {i < segments.length - 1 && ' / '}
          </span>
        ))}
      </p>

      <details class="docs-toc-mobile">
        <summary>{isZh ? '本页目录' : 'On this page'}</summary>
        <nav id="docs-toc-nav-mobile" aria-label={isZh ? '本页目录' : 'On this page'}></nav>
      </details>

      <slot />

      <nav class="docs-pager" aria-label="Pagination">
        {prev ? (
          <a href={prev.slug === '' ? base : `${base}/${prev.slug}`}>
            <span class="dir">← {isZh ? '上一页' : 'Previous'}</span>
            <span class="ttl">{isZh ? prev.zhTitle : prev.title}</span>
          </a>
        ) : <div></div>}
        {next ? (
          <a href={next.slug === '' ? base : `${base}/${next.slug}`} class="right">
            <span class="dir">{isZh ? '下一页' : 'Next'} →</span>
            <span class="ttl">{isZh ? next.zhTitle : next.title}</span>
          </a>
        ) : <div></div>}
      </nav>
    </article>

    <aside class="docs-toc" aria-label={isZh ? '本页目录' : 'On this page'}>
      <p class="docs-toc-title">{isZh ? '本页目录' : 'On this page'}</p>
      <nav id="docs-toc-nav"></nav>
    </aside>
  </div>

  <script>
    // Sidebar scroll persistence — keep the user's place when navigating between
    // doc pages. Saves on scroll (debounced) and restores on every page load.
    (function () {
      const KEY = 'sw-docs-sidebar-scroll';
      const sidebar = document.querySelector<HTMLElement>('.docs-sidebar');
      if (!sidebar) return;

      // Restore.
      try {
        const saved = sessionStorage.getItem(KEY);
        if (saved !== null) sidebar.scrollTop = Number(saved);
      } catch {}

      // Make sure the active link is visible — scroll into view if hidden.
      const active = sidebar.querySelector<HTMLElement>('a[aria-current="page"]');
      if (active) {
        const rect = active.getBoundingClientRect();
        const sidebarRect = sidebar.getBoundingClientRect();
        if (rect.top < sidebarRect.top || rect.bottom > sidebarRect.bottom) {
          active.scrollIntoView({ block: 'center' });
        }
      }

      // Save (debounced).
      let timer: number | undefined;
      sidebar.addEventListener('scroll', () => {
        if (timer) clearTimeout(timer);
        timer = window.setTimeout(() => {
          try { sessionStorage.setItem(KEY, String(sidebar.scrollTop)); } catch {}
        }, 80);
      });
    })();
  </script>

  <script>
    // Auto in-page TOC ("On this page") — extracts h2/h3 from .docs-content,
    // ensures stable ids, builds a nested nav, highlights on scroll, smooth-scrolls
    // on click. Populates both the desktop right rail and the mobile <details>.
    (function () {
      const article = document.querySelector<HTMLElement>('.docs-content');
      const desktopMount = document.getElementById('docs-toc-nav');
      const mobileMount = document.getElementById('docs-toc-nav-mobile');
      const mobileWrap = document.querySelector<HTMLDetailsElement>('details.docs-toc-mobile');
      const desktopAside = document.querySelector<HTMLElement>('.docs-toc');
      if (!article || (!desktopMount && !mobileMount)) return;

      // Collect headings (skip anything inside the TOC itself or the mobile <details>).
      const headings = Array.from(
        article.querySelectorAll<HTMLHeadingElement>('h2, h3')
      ).filter((h) => !h.closest('details.docs-toc-mobile') && !h.closest('.docs-toc'));

      if (headings.length === 0) {
        if (desktopAside) desktopAside.style.display = 'none';
        if (mobileWrap) mobileWrap.style.display = 'none';
        return;
      }

      const slugify = (s: string) =>
        s
          .toLowerCase()
          .replace(/[ -⁯⸀-⹿'`~!@#$%^&*()+={}\[\]|\\:;"<>,.?/]/g, '')
          .replace(/\s+/g, '-')
          .replace(/^-+|-+$/g, '');

      const used = new Set<string>();
      let counter = 0;
      headings.forEach((h) => {
        if (!h.id) {
          const text = (h.textContent || '').trim();
          let id = slugify(text);
          // Chinese / non-ASCII / empty slugs fall back to a counter id.
          if (!id) id = 'h-' + (++counter);
          let unique = id;
          let n = 2;
          while (used.has(unique) || document.getElementById(unique)) {
            unique = id + '-' + n++;
          }
          h.id = unique;
          used.add(unique);
        } else {
          used.add(h.id);
        }
      });

      // Build nested list: h3s nest under the preceding h2.
      const buildNav = () => {
        const root = document.createElement('ul');
        let currentH2List: HTMLUListElement | null = null;

        headings.forEach((h) => {
          const li = document.createElement('li');
          const a = document.createElement('a');
          a.href = '#' + h.id;
          a.textContent = (h.textContent || '').trim();
          a.dataset.tocFor = h.id;
          li.appendChild(a);

          if (h.tagName === 'H2') {
            root.appendChild(li);
            currentH2List = null;
          } else {
            // h3
            if (!currentH2List) {
              const lastLi = root.lastElementChild as HTMLLIElement | null;
              if (lastLi) {
                currentH2List = document.createElement('ul');
                lastLi.appendChild(currentH2List);
              } else {
                // h3 with no preceding h2 — place at root.
                root.appendChild(li);
                return;
              }
            }
            currentH2List.appendChild(li);
          }
        });
        return root;
      };

      if (desktopMount) desktopMount.appendChild(buildNav());
      if (mobileMount) mobileMount.appendChild(buildNav());

      // Smooth scroll on click; close mobile details after navigation.
      const allLinks = document.querySelectorAll<HTMLAnchorElement>(
        '#docs-toc-nav a, #docs-toc-nav-mobile a'
      );
      allLinks.forEach((a) => {
        a.addEventListener('click', (e) => {
          const id = a.getAttribute('href')?.slice(1);
          if (!id) return;
          const target = document.getElementById(id);
          if (!target) return;
          e.preventDefault();
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          history.replaceState(null, '', '#' + id);
          if (mobileWrap && mobileWrap.open) mobileWrap.open = false;
        });
      });

      // Active-section highlighting via IntersectionObserver.
      const setActive = (id: string) => {
        document
          .querySelectorAll<HTMLAnchorElement>(
            '#docs-toc-nav a.active, #docs-toc-nav-mobile a.active'
          )
          .forEach((el) => el.classList.remove('active'));
        document
          .querySelectorAll<HTMLAnchorElement>(
            `#docs-toc-nav a[data-toc-for="${id}"], #docs-toc-nav-mobile a[data-toc-for="${id}"]`
          )
          .forEach((el) => el.classList.add('active'));
      };

      const visible = new Map<string, number>(); // id -> intersectionRatio
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            const id = (entry.target as HTMLElement).id;
            if (entry.isIntersecting) {
              visible.set(id, entry.intersectionRatio);
            } else {
              visible.delete(id);
            }
          });
          if (visible.size > 0) {
            // Pick the heading nearest the top of the viewport (first by document order).
            for (const h of headings) {
              if (visible.has(h.id)) {
                setActive(h.id);
                break;
              }
            }
          }
        },
        {
          // Treat the band ~80px from the top to ~70% down the viewport as "active".
          rootMargin: '-80px 0px -70% 0px',
          threshold: [0, 1],
        }
      );
      headings.forEach((h) => observer.observe(h));

      // Initial active = first heading.
      setActive(headings[0].id);
    })();
  </script>
</Base>
